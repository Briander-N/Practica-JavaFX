<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="246.0" prefWidth="263.0" spacing="20.0" style="-fx-background-color: black;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.example.practicajavafx2.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <VBox prefHeight="213.0" prefWidth="223.0" style="-fx-background-color: #001442; -fx-background-radius: 20;">
      <children>
         <Label fx:id="lblTitulo" alignment="CENTER" text="ACCESO" textFill="#8aadff" textOverrun="CLIP">
            <font>
               <Font name="System Bold" size="21.0" />
            </font>
         </Label>
         <Label fx:id="lblUsuario" text="Usuario" textFill="WHITE">
            <font>
               <Font name="System Bold" size="12.0" />
            </font>
         </Label>
         <TextField fx:id="txtUsuario" promptText="Ingrese su usuario" />
         <Label fx:id="lblContrasena" text="Contraseña" textFill="WHITE">
            <font>
               <Font name="System Bold" size="12.0" />
            </font>
         </Label>
         <TextField fx:id="txtContrasena" promptText="Ingrese su contraseña" />
         <Label fx:id="lblValidacion" textFill="#ff8f8f">
            <padding>
               <Insets bottom="10.0" top="10.0" />
            </padding>
            <font>
               <Font name="System Bold Italic" size="15.0" />
            </font>
         </Label>
          <Button fx:id="btnValidar" alignment="CENTER" contentDisplay="CENTER" onAction="#validarCredenciales" prefHeight="25.0" prefWidth="78.0" style="-fx-background-color: #8aadff;" text="Validar" textFill="WHITE">
            <font>
               <Font name="System Bold" size="12.0" />
            </font>
         </Button>
      </children>
      <padding>
         <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
      </padding>
   </VBox>
</VBox>
