<?xml version="1.0" encoding="UTF-8"?>

<!-- Importes necesarios para enlazar el css y ordenar componentes -->
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.practicajavafx2.AdministradorController">

   <!-- Enlace directo y correcto al archivo CSS -->
   <stylesheets>
      <URL value="@../../../css/estilos.css" />
   </stylesheets>

   <children>
      <Label id="lblTituloAdmin" fx:id="lblTituloAdmin" alignment="CENTER" prefHeight="31.0" prefWidth="259.0" text="ADMINISTRADOR">
         <font>
            <Font name="System Bold" size="21.0" />
         </font>
      </Label>

      <!-- Agregamos spacing="8.0" para separar las etiquetas de sus inputs -->
      <VBox id="cajaFormulario" spacing="8.0">
         <children>
            <Label id="lblProducto" fx:id="lblProducto" text="Nombre Producto:" />
            <TextField id="txtProducto" fx:id="txtProducto" prefHeight="25.0" prefWidth="237.0" />

            <Label id="lblCategoria" fx:id="lblCategoria" text="Categoría:" />
            <TextField id="txtCategoria" fx:id="txtCategoria" prefHeight="25.0" prefWidth="237.0" />

            <Label id="lblPrecio" fx:id="lblPrecio" text="Precio:" />
            <TextField id="txtPrecio" fx:id="txtPrecio" prefHeight="25.0" prefWidth="237.0" />

            <Label id="lblStock" fx:id="lblStock" text="Stock:" />
            <TextField id="txtStock" fx:id="txtStock" prefHeight="25.0" prefWidth="237.0" />
         </children>
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </VBox>

      <Label id="lblMensajeProducto" fx:id="lblMensajeProducto" />
      <Button id="btnRegistrarProducto" fx:id="btnRegistrarProducto" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="25.0" prefWidth="121.0" text="Registrar Producto" />
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>
