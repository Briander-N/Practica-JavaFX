<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<!-- Añadimos un espaciado general de 15.0 entre los bloques del formulario -->
<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.practicajavafx2.CajeroController">
   <children>

      <!-- Título principal estilo Bootstrap (Letra grande y color azul corporativo) -->
      <Label fx:id="lblTituloCajero" text="CAJERO" styleClass="h1, text-primary" />

      <!-- Contenedor del formulario con un espaciado de 8.0 entre campos -->
      <VBox spacing="8.0">
         <children>
            <!-- Campo: Nombre -->
            <Label fx:id="lblNombreCliente" text="Nombre:" styleClass="strong, text-muted" />
            <TextField fx:id="txtNombreCliente" prefHeight="35.0" prefWidth="331.0" styleClass="text-field" />

            <!-- Campo: Cédula -->
            <Label fx:id="lblCedulaCliente" text="Cédula:" styleClass="strong, text-muted" />
            <TextField fx:id="txtCedulaCliente" prefHeight="35.0" prefWidth="331.0" styleClass="text-field" />

            <!-- Campo: Teléfono -->
            <Label fx:id="lblTelefonoCliente" text="Teléfono:" styleClass="strong, text-muted" />
            <TextField fx:id="txtTelefonoCliente" prefHeight="35.0" prefWidth="331.0" styleClass="text-field" />

            <!-- Campo: Dirección -->
            <Label fx:id="lblDireccionCliente" text="Dirección:" styleClass="strong, text-muted" />
            <TextField fx:id="txtDireccionCliente" prefHeight="35.0" prefWidth="331.0" styleClass="text-field" />
         </children>
      </VBox>

      <!-- Mensaje de estado estilo alerta de error (Oculto o vacío inicialmente) -->
      <Label fx:id="lblMensajeCajero" prefWidth="331.0" styleClass="text-danger, strong" />

      <!-- Botón de éxito grande de Bootstrap (Color Verde) -->
      <Button fx:id="btnRegistrarCliente" mnemonicParsing="false" prefHeight="40.0" prefWidth="180.0" text="Registrar Cliente" styleClass="btn, btn-success" />

   </children>
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
</VBox>
